{
  "name": "manor-butler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run check:max-loc && npm run build:web && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "check:max-loc": "node ./scripts/check-max-loc.mjs",
    "dev:start": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "test": "tsx --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.73.0",
    "@mariozechner/pi-coding-agent": "0.73.0",
    "@sinclair/typebox": "^0.34.41",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "http-proxy": "^1.18.1",
    "jszip": "^3.10.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "ws": "^8.18.3"
  },
  "overrides": {
    "basic-ftp": "6.0.1",
    "follow-redirects": "1.16.0",
    "ip-address": "10.2.0",
    "postcss": "8.5.14",
    "protobufjs": "8.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }

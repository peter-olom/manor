# Manor local configuration
#
# Copy this file to .env or run ./install.sh to generate one.
# Do not commit .env. It may contain local secrets and auth settings.

BUTLER_HOST_PORT=8180

# Required. The installer generates a local value automatically.
# If configuring manually, use a long random value.
RUNTIME_BROKER_TOKEN=

# Optional package auto-update behavior at container startup.
MANOR_CODEX_AUTO_UPDATE=0
MANOR_CODEX_AUTO_UPDATE_VERSION=latest
MANOR_CODEX_AUTO_UPDATE_REQUIRED=0
MANOR_PI_AUTO_UPDATE=0
MANOR_PI_AUTO_UPDATE_VERSION=latest
MANOR_PI_AUTO_UPDATE_REQUIRED=0

# Optional auth bootstrap. Leave empty when using device-code login.
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
